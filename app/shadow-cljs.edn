{:deps true
 :dev-http {8020 "public"}
 :builds
 {:app {:target :browser
        :output-dir "public/js"
        :asset-path "/js"
        :modules {:main {:init-fn wbr.app.core/init}}
        :devtools {:http-root "public" :http-port 8020}}
  :test {:target :node-test
         :output-to "out/node-tests.js"}}}
